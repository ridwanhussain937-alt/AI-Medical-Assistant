DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_TIME_ZONE=UTC
DJANGO_SITE_DOMAIN=127.0.0.1:8000
DJANGO_SITE_NAME=AI Medical Assistant
DJANGO_USE_X_FORWARDED_HOST=true
DJANGO_SECURE_PROXY_SSL_HEADER=true

# Database
DATABASE_URL=
DJANGO_DB_CONN_MAX_AGE=600
DJANGO_DB_SSL_REQUIRE=false
DJANGO_SQLITE_PATH=

# OTP and email delivery
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=noreply@aimedical.local
# Recommended for free Render deployments: use the Resend HTTP API
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Optional override, usually leave as-is
# RESEND_API_URL=https://api.resend.com/emails
# Gmail SMTP example for free email OTP delivery:
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DJANGO_EMAIL_HOST=smtp.gmail.com
# DJANGO_EMAIL_PORT=587
# DJANGO_EMAIL_HOST_USER=your-gmail-address
# DJANGO_EMAIL_HOST_PASSWORD=your-gmail-app-password
# DJANGO_EMAIL_USE_TLS=true
DJANGO_EMAIL_HOST=smtp.example.com
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=true
DJANGO_EMAIL_USE_SSL=false

# Security toggles for deployment
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false
DJANGO_SECURE_SSL_REDIRECT=false
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=false
DJANGO_SECURE_HSTS_PRELOAD=false
DJANGO_STATIC_ROOT=
DJANGO_MEDIA_ROOT=
DJANGO_SERVE_MEDIA=false
DJANGO_MODEL_ARTIFACT_ROOT=
DJANGO_INLINE_TRAINING_WORKER=false
DJANGO_INLINE_TRAINING_WORKER_POLL_SECONDS=15

# AI integrations
GROQ_API_KEY=
REGISTRATION_OTP_EXPIRY_MINUTES=10
REGISTRATION_OTP_MAX_ATTEMPTS=5
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Optional demo admin provisioning for one-click deployments
DJANGO_CREATE_DEMO_ADMIN=false
DJANGO_DEMO_ADMIN_USERNAME=
DJANGO_DEMO_ADMIN_EMAIL=
DJANGO_DEMO_ADMIN_PASSWORD=

# Optional runtime tuning
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=180
TRAINING_WORKER_POLL_SECONDS=15
